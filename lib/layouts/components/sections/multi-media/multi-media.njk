{% from "components/_partials/ctas/ctas.njk" import ctas %}
{% from "components/_partials/text/text.njk" import text %}
{% from "components/_partials/audio/audio.njk" import audio %}
{% from "components/_partials/icon/icon.njk" import icon %}
{% from "components/_partials/image/image.njk" import image %}
{% from "components/_partials/video/video.njk" import video %}
{% from "components/_partials/lottie/lottie.njk" import lottie %}
{% from "components/_partials/iframe/iframe.njk" import iframe %}
{% from "components/_partials/givebutter-widget/givebutter-widget.njk" import givebutterWidget %}
{% from "components/_partials/session-list/session-list.njk" import sessionList %}
{% from "components/_partials/disclosure/disclosure.njk" import disclosures %}

<div class="content {% if section.isReverse %}is-reverse{% endif %}">
  {% if section.mediaType === "audio" %}
    <div class="media">{{ audio(section.audio)}}</div>
  {% endif %}

  {% if section.mediaType === "image" %}
    <div class="media">{{ image(section.image)}}</div>
  {% endif %}

  {% if section.mediaType === "video"%}
    {% set videoData = section.video %}
    {{ video(videoData) }}
  {% endif %}

  {% if section.mediaType === "icon"%}
    <div class="media">{{ icon(section.icon) }}</div>
  {% endif %}

  {% if section.mediaType === "lottie"%}
    <div class="media">{{ lottie(section.lottie) }}</div>
  {% endif %}

  {% if section.mediaType === "text" %}
    <div class="media is-text flow">{{ text(section.mediaText) }}</div>
  {% endif %}

  {% if section.mediaType === "iframe" and section.iframe.src %}
    <div class="media is-iframe">{{ iframe(section.iframe) }}</div>
  {% endif %}

  {% if section.mediaType === "givebutter" and section.givebutter.widgetId %}
    <div class="media is-givebutter">{{ givebutterWidget(section.givebutter) }}</div>
  {% endif %}

  {% set hasSessions = section.sessions and section.sessions.length > 0 %}
  {% set hasDisclosures = section.disclosures and section.disclosures.length > 0 %}
  {% if section.text | hasText or hasSessions or hasDisclosures %}
    <div class="text flow">
      {% if section.text | hasText %}
        <div class="prose flow">{{ text(section.text)}}</div>
      {% endif %}
      {% if section.ctas | hasCtas %}
        {{ ctas(section.ctas) }}
      {% endif %}
      {% if hasSessions %}
        {{ sessionList(section.endpoint, section.sessions, section.sessionsTitle) }}
      {% endif %}
      {% if hasDisclosures %}
        {{ disclosures(section.disclosures) }}
      {% endif %}
    </div><!-- .text -->
  {% endif %}

</div>