{
  "name": "multi-media",
  "type": "section",
  "styles": ["multi-media.css"],
  "scripts": [],
  "requires": [
    "ctas",
    "text",
    "image",
    "video",
    "audio",
    "icon",
    "lottie",
    "iframe",
    "session-list",
    "givebutter-widget",
    "commons"
  ],
  "validation": {
    "required": ["sectionType", "mediaType"],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "multi-media"
      },
      "mediaType": {
        "type": "string",
        "enum": ["image", "video", "audio", "icon", "lottie", "text", "iframe", "givebutter"]
      },
      "endpoint": {
        "type": "string",
        "description": "Apps Script web app /exec URL for the optional session list"
      },
      "sessionsTitle": {
        "type": "string",
        "description": "Heading rendered above the optional session list"
      },
      "sessions": {
        "type": "array",
        "items": {
          "properties": {
            "sessionId": {
              "type": "string"
            },
            "dateDisplay": {
              "type": "string"
            },
            "timeDisplay": {
              "type": "string"
            },
            "hosted": {
              "type": "boolean"
            }
          }
        }
      },
      "isReverse": {
        "type": "boolean"
      },
      "isDisabled": {
        "type": "boolean"
      },
      "containerTag": {
        "type": "string",
        "enum": ["section", "aside", "div", "article"]
      },
      "containerFields.inContainer": {
        "type": "boolean"
      },
      "containerFields.isAnimated": {
        "type": "boolean"
      },
      "containerFields.noMargin.top": {
        "type": "boolean"
      },
      "containerFields.noMargin.bottom": {
        "type": "boolean"
      },
      "containerFields.noPadding.top": {
        "type": "boolean"
      },
      "containerFields.noPadding.bottom": {
        "type": "boolean"
      },
      "containerFields.background.isDark": {
        "type": "boolean"
      },
      "containerFields.background.imageScreen": {
        "type": "string",
        "enum": ["light", "dark", "none"]
      },
      "text.titleTag": {
        "type": "string",
        "enum": ["h1", "h2", "h3", "h4", "h5", "h6"],
        "default": "h2"
      },
      "ctas": {
        "type": "array",
        "items": {
          "properties": {
            "isButton": {
              "type": "boolean"
            },
            "buttonStyle": {
              "type": "string",
              "enum": ["primary", "secondary", "tertiary", "inverted"]
            },
            "isSmall": {
              "type": "boolean"
            }
          }
        }
      },
      "givebutter.accountId": {
        "type": "string",
        "description": "The org's Givebutter account id"
      },
      "givebutter.widgetId": {
        "type": "string",
        "description": "Widget element id from the pasted embed URL"
      }
    }
  },
  "fields": {
    "mediaType": {
      "widget": "select",
      "label": "Media type",
      "enum": ["image", "video", "audio", "icon", "lottie", "text", "iframe", "givebutter"],
      "default": "image"
    },
    "isReverse": {
      "widget": "checkbox",
      "label": "Reverse layout",
      "default": false
    },
    "text": {
      "$use": "text"
    },
    "mediaText": {
      "$use": "text"
    },
    "iframe": {
      "$use": "iframe"
    },
    "image": {
      "$use": "image"
    },
    "video": {
      "$use": "video"
    },
    "audio": {
      "$use": "audio"
    },
    "icon": {
      "$use": "icon"
    },
    "lottie": {
      "$use": "lottie"
    },
    "ctas": {
      "$use": "ctas"
    },
    "$extends": ["commons"]
  }
}
