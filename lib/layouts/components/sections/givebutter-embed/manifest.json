{
  "name": "givebutter-embed",
  "type": "section",
  "styles": ["givebutter-embed.css"],
  "scripts": [],
  "requires": ["text", "commons"],
  "validation": {
    "required": ["sectionType", "embedUrl"],
    "properties": {
      "sectionType": {
        "type": "string",
        "const": "givebutter-embed"
      },
      "embedUrl": {
        "type": "string"
      },
      "containerFields.inContainer": {
        "type": "boolean"
      },
      "containerFields.isAnimated": {
        "type": "boolean"
      },
      "text.titleTag": {
        "type": "string",
        "enum": ["h1", "h2", "h3", "h4", "h5", "h6"],
        "default": "h2"
      }
    }
  },
  "fields": {
    "embedUrl": {
      "widget": "text",
      "label": "Givebutter embed URL",
      "default": ""
    },
    "text": {
      "$use": "text"
    },
    "$extends": ["commons"]
  }
}
