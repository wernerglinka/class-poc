{% from "components/_partials/text/text.njk" import text %}
{% from "components/_partials/session-list/session-list.njk" import sessionList %}

{#
  class-sessions
  Standalone section wrapper around the session-list partial, which
  holds the markup, styles, and behavior (availability refresh and
  volunteer signup). See _partials/session-list.

  Required section properties:
  - endpoint: string - the Apps Script web app /exec URL
  - sessions: array of { sessionId, dateDisplay, timeDisplay, hosted }
#}

<div class="content container">
  {% if section.text %}
    <div class="text flow">
      {{ text(section.text) }}
    </div>
  {% endif %}

  {{ sessionList(section.endpoint, section.sessions) }}
</div>
